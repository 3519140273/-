<launch>
  <!-- 启动 Gazebo 空世界 -->
  <include file="$(find gazebo_ros)/launch/empty_world.launch">
    <arg name="world_name" value="empty.world"/>
    <arg name="use_sim_time" value="true"/>
    <arg name="gui" value="true"/>
  </include>

  <!-- 加载小车模型 -->
  <param name="robot_description" command="$(find xacro)/xacro $(find car_description)/urdf/car.urdf"/>

  <!-- 发布关节状态 -->
  <node name="robot_state_publisher" pkg="robot_state_publisher" type="robot_state_publisher">
    <param name="publish_frequency" value="30.0"/>
  </node>

  <!-- 在 Gazebo 中生成小车 -->
  <node name="spawn_car" pkg="gazebo_ros" type="spawn_model"
        args="-param robot_description -urdf -model car -x 0 -y 0 -z 0.1"/>

  <!-- 启动控制器管理器 -->
  <node name="controller_manager" pkg="controller_manager" type="controller_manager" respawn="true"/>
  <rosparam file="$(find car_description)/config/controllers.yaml" command="load"/>

  <!-- 启动 RViz -->
  <node name="rviz" pkg="rviz" type="rviz"/>
</launch>
