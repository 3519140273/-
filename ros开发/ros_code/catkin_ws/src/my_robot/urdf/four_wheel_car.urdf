<?xml version="1.0"?>
<robot name="four_wheel_car">

  <material name="black"><color rgba="0 0 0 1"/></material>
  <material name="blue"><color rgba="0 0 0.8 1"/></material>
  <material name="red"><color rgba="0.8 0 0 1"/></material>
  <material name="grey"><color rgba="0.5 0.5 0.5 1"/></material>

  <link name="base_footprint"/>
  <joint name="base_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0 0 0.10"/>
  </joint>

  <link name="base_link">
    <visual>
      <geometry><box size="0.5 0.3 0.16"/></geometry>
      <material name="blue"/>
    </visual>
  </link>

  <link name="rear_left_wheel">
    <visual>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry><cylinder length="0.05" radius="0.08"/></geometry>
      <material name="black"/>
    </visual>
  </link>
  <joint name="rear_left_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="rear_left_wheel"/>
    <origin xyz="-0.18 0.18 -0.02" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <link name="rear_right_wheel">
    <visual>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry><cylinder length="0.05" radius="0.08"/></geometry>
      <material name="black"/>
    </visual>
  </link>
  <joint name="rear_right_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="rear_right_wheel"/>
    <origin xyz="-0.18 -0.18 -0.02" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <link name="front_left_steer">
    <visual>
      <geometry><cylinder length="0.04" radius="0.03"/></geometry>
      <material name="grey"/>
    </visual>
  </link>
  <joint name="front_left_steer_joint" type="revolute">
    <parent link="base_link"/>
    <child link="front_left_steer"/>
    <origin xyz="0.18 0.18 -0.02" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-0.6" upper="0.6" effort="10" velocity="3"/>
  </joint>

  <link name="front_left_wheel">
    <visual>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry><cylinder length="0.05" radius="0.08"/></geometry>
      <material name="black"/>
    </visual>
  </link>
  <joint name="front_left_wheel_joint" type="continuous">
    <parent link="front_left_steer"/>
    <child link="front_left_wheel"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <link name="front_right_steer">
    <visual>
      <geometry><cylinder length="0.04" radius="0.03"/></geometry>
      <material name="grey"/>
    </visual>
  </link>
  <joint name="front_right_steer_joint" type="revolute">
    <parent link="base_link"/>
    <child link="front_right_steer"/>
    <origin xyz="0.18 -0.18 -0.02" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-0.6" upper="0.6" effort="10" velocity="3"/>
  </joint>

  <link name="front_right_wheel">
    <visual>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry><cylinder length="0.05" radius="0.08"/></geometry>
      <material name="black"/>
    </visual>
  </link>
  <joint name="front_right_wheel_joint" type="continuous">
    <parent link="front_right_steer"/>
    <child link="front_right_wheel"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <link name="camera_link">
    <visual>
      <geometry><box size="0.04 0.06 0.04"/></geometry>
      <material name="red"/>
    </visual>
  </link>
  <joint name="camera_joint" type="fixed">
    <parent link="base_link"/>
    <child link="camera_link"/>
    <origin xyz="0.2 0 0.10" rpy="0 0 0"/>
  </joint>

</robot>
